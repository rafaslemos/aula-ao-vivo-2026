{
  "version": 2,
  "framework": null,
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/handler.js": {
      "includeFiles": "dist/server/**",
      "memory": 512
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/handler" }
  ]
}
